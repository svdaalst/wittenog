{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "WitteNog App",
      "runtimeExecutable": "dotnet",
      "runtimeArgs": ["run", "--project", "src/WitteNog.App", "-f", "net9.0-windows10.0.19041.0"],
