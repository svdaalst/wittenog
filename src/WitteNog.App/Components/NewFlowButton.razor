@inject IMediator Mediator
@inject IJSRuntime JS
@implements IDisposable
@using MediatR
@using WitteNog.Application.Commands

<div @ref="_container">
    <button class="new-flow-btn" data-action="open">+ Diagram</button>

    @if (_showModal)
    {
        <div class="modal-overlay" data-action="cancel">
            <div class="modal">
                <h3>Nieuw diagram</h3>
                <input @bind="_title" @bind:event="oninput" placeholder="Naam (optioneel)..." />
                <div class="modal-actions">
                    <button data-action="create">Aanmaken</button>
                    <button data-action="cancel">Annuleren</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string VaultPath { get; set; } = string.Empty;
    [Parameter] public string PageLink { get; set; } = string.Empty;
    [Parameter] public EventCallback OnFlowCreated { get; set; }

    private bool _showModal;
    private string _title = string.Empty;
    private ElementReference _container;
    private DotNetObjectReference<NewFlowButton>? _dotNetRef;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("OnboardingDelegate.attach", _container, _dotNetRef);
        }
    }

    [JSInvokable]
    public async Task HandleAction(string action)
    {
        if (action == "open")
        {
            _showModal = true;
            await InvokeAsync(StateHasChanged);
        }
        else if (action == "create")
        {
            await CreateAsync();
        }
        else if (action == "cancel")
        {
            _showModal = false;
            _title = string.Empty;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task CreateAsync()
    {
        var links = string.IsNullOrWhiteSpace(PageLink)
            ? Array.Empty<string>()
            : new[] { PageLink };
        await Mediator.Send(new CreateFlowCommand(VaultPath, links, _title.Trim()));
        _title = string.Empty;
        _showModal = false;
        await InvokeAsync(StateHasChanged);
        await OnFlowCreated.InvokeAsync();
    }

    public void Dispose() => _dotNetRef?.Dispose();
}
