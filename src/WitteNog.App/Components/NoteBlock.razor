@inject IMediator Mediator
@inject INavigationService NavService
@inject IJSRuntime JS
@inject WitteNog.App.Services.EditModeCoordinatorService EditModeCoordinator
@implements IDisposable
@using MediatR
@using WitteNog.App.Helpers
@using WitteNog.App.Models
@using WitteNog.App.Services
@using WitteNog.Application.Commands
@using WitteNog.Core.Models

<div class="note-block @(_editing ? "editing" : "")" @ref="_container">
    @if (_renaming)
    {
        <div class="note-title-bar">
            <input id="@_renameInputId" class="note-rename-input" type="text" value="@Note.Id" />
            <button class="note-rename-confirm" data-action="confirm-rename" title="Opslaan">✓</button>
            <button class="note-rename-cancel" data-action="cancel-rename" title="Annuleren">✕</button>
        </div>
    }
    else
    {
        <div class="note-title-bar">
            <span class="note-title">@((MarkupString)RenderTitleLinks(string.IsNullOrEmpty(Note.Title) ? Note.Id : Note.Title))</span>
            @if (_editing)
            {
                <button class="note-edit-save" data-action="save" title="Opslaan">Opslaan</button>
                <button class="note-edit-cancel" data-action="cancel" title="Annuleren">Annuleren</button>
            }
            else
            {
                <button class="note-rename-btn" data-action="start-rename" title="Hernoemen">✎</button>
            }
        </div>
    }

    @if (_editing)
    {
        <TipTapEditor @ref="_editor" InitialContent="@StripLeadingH1(Note.Content)" />
    }
    else
    {
        @if (string.IsNullOrWhiteSpace(StripLeadingH1(Note.Content)))
        {
            <div class="note-content note-content-empty" data-action="edit-click">✎ Klik om te bewerken</div>
        }
        else
        {
            <div class="note-content" data-action="edit">
                @((MarkupString)MarkdownRenderer.Render(StripLeadingH1(Note.Content), Note.FilePath, GetH1LineOffset(Note.Content)))
            </div>
        }
        @if (!_renaming)
        {
            <div class="note-actions-bar">
                <RecordingPanel @ref="_recordingPanel" FilePath="@Note.FilePath" />
                <button class="note-delete-btn" data-action="confirm-delete">✕</button>
            </div>
        }
    }

    @if (_showConfirm)
    {
        <div class="modal-overlay" data-action="cancel-delete">
            <div class="modal">
                <h3>Notitie verwijderen?</h3>
                <p class="modal-body">@Note.Id</p>
                <div class="modal-actions">
                    <button class="modal-btn-primary" data-action="delete">Verwijderen</button>
                    <button class="modal-btn-secondary" data-action="cancel-delete">Annuleren</button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public AtomicNote Note { get; set; } = null!;
    [Parameter] public string VaultPath { get; set; } = string.Empty;
    [Parameter] public string TabQuery { get; set; } = string.Empty;
    [Parameter] public EventCallback OnSaved { get; set; }

    private bool _editing;
    private bool _renaming;
    private bool _showConfirm;
    private TipTapEditor? _editor;
    private RecordingPanel? _recordingPanel;
    private ElementReference _container;
    private DotNetObjectReference<NoteBlock>? _dotNetRef;
    private string? _lastInitedContent;
    private string _renameInputId = string.Empty;

    protected override void OnParametersSet()
    {
        _renameInputId = $"rename-{System.Text.RegularExpressions.Regex.Replace(Note.Id, @"[^\w]", "-")}";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("NoteBlockDelegate.attach", _container, _dotNetRef);
        }
        // Only re-init headings when note content actually changes, not on every re-render.
        // This prevents collapse state from being wiped when VirtualCanvas re-renders (e.g. after clicking Inklappen).
        if (!_editing && Note.Content != _lastInitedContent)
        {
            _lastInitedContent = Note.Content;
            await JS.InvokeVoidAsync("HeadingCollapse.initBlock", _container);
        }
    }

    /// <summary>Called from JS when an audio file link is clicked — opens via the default OS app.</summary>
    [JSInvokable]
    public void OpenAudioFile(string relativePath)
    {
        var noteDir = Path.GetDirectoryName(Note.FilePath) ?? string.Empty;
        var absolutePath = Path.GetFullPath(Path.Combine(noteDir, relativePath));

        // Guard against path traversal: the resolved file must live inside the vault directory.
        var vaultDir = Path.GetFullPath(VaultPath.TrimEnd(Path.DirectorySeparatorChar,
                                                           Path.AltDirectorySeparatorChar)
                       + Path.DirectorySeparatorChar);
        if (!absolutePath.StartsWith(vaultDir, StringComparison.OrdinalIgnoreCase))
            return;

        System.Diagnostics.Process.Start(
            new System.Diagnostics.ProcessStartInfo(absolutePath) { UseShellExecute = true });
    }

    /// <summary>Called from JS when a [[WikiLink]] in the rendered content is clicked.</summary>
    [JSInvokable]
    public void NavigateToWikiLink(string link, bool shiftKey)
    {
        var type = System.Text.RegularExpressions.Regex.IsMatch(link, @"^\d{4}-\d{2}-\d{2}$")
            ? TabType.DailyPage : TabType.TopicPage;
        if (shiftKey) NavService.OpenNewTab(type, link);
        else NavService.OpenTab(type, link);
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task HandleNoteAction(string action, string taskId = "")
    {
        switch (action)
        {
            case "complete-inline":
                try
                {
                    await Mediator.Send(new CompleteTaskCommand(VaultPath, taskId));
                    await OnSaved.InvokeAsync();
                }
                catch (Exception ex)
                {
                    Console.Error.WriteLine($"Taak voltooien mislukt: {ex.Message}");
                }
                return;
            case "edit-click":
            case "edit":
                if (!_editing)
                {
                    await EditModeCoordinator.TryEnterEditModeAsync(Note.Id, async () =>
                    {
                        if (_editor != null)
                        {
                            var content = await GetFullContentAsync();
                            await Mediator.Send(new UpdateNoteCommand(Note.FilePath, content, TabQuery));
                        }
                        _editing = false;
                        await JS.InvokeVoidAsync("NoteBlockDelegate.clearActiveRef");
                        await InvokeAsync(StateHasChanged);
                        await OnSaved.InvokeAsync();
                    });
                    _editing = true;
                    await JS.InvokeVoidAsync("NoteBlockDelegate.setActiveRef", _dotNetRef);
                    await InvokeAsync(StateHasChanged);
                }
                break;
            case "save":
                await JS.InvokeVoidAsync("NoteBlockDelegate.clearActiveRef");
                await SaveAsync();
                break;
            case "cancel":
                _editing = false;
                await JS.InvokeVoidAsync("NoteBlockDelegate.clearActiveRef");
                EditModeCoordinator.ExitEditMode(Note.Id);
                await InvokeAsync(StateHasChanged);
                break;
            case "start-rename":
                _renaming = true;
                await InvokeAsync(StateHasChanged);
                break;
            case "confirm-rename":
                await RenameAsync();
                break;
            case "cancel-rename":
                _renaming = false;
                await InvokeAsync(StateHasChanged);
                break;
            case "confirm-delete":
                _showConfirm = true;
                await InvokeAsync(StateHasChanged);
                break;
            case "delete":
                await DeleteAsync();
                break;
            case "cancel-delete":
                _showConfirm = false;
                await InvokeAsync(StateHasChanged);
                break;
            case "record":
                if (_recordingPanel is not null)
                    await _recordingPanel.HandleRecordAction("record");
                break;
            case "stop":
                if (_recordingPanel is not null)
                    await _recordingPanel.HandleRecordAction("stop");
                break;
        }
    }

    private async Task<string> GetFullContentAsync()
    {
        var raw = await _editor!.GetContentAsync();
        return string.IsNullOrEmpty(Note.Title)
            ? raw
            : $"# {Note.Title}\n\n{raw}";
    }

    private async Task SaveAsync()
    {
        if (_editor == null) return;
        var content = await GetFullContentAsync();
        await Mediator.Send(new UpdateNoteCommand(Note.FilePath, content, TabQuery));
        _editing = false;
        EditModeCoordinator.ExitEditMode(Note.Id);
        await OnSaved.InvokeAsync();
    }

    private async Task RenameAsync()
    {
        var newSlug = await JS.InvokeAsync<string>("getInputValue", _renameInputId);
        newSlug = newSlug?.Trim() ?? string.Empty;
        if (string.IsNullOrEmpty(newSlug) || newSlug == Note.Id)
        {
            _renaming = false;
            await InvokeAsync(StateHasChanged);
            return;
        }
        _renaming = false;
        await Mediator.Send(new RenameNoteCommand(Note.FilePath, newSlug, VaultPath));
        await OnSaved.InvokeAsync();
    }

    private async Task DeleteAsync()
    {
        _showConfirm = false;
        await Mediator.Send(new DeleteNoteCommand(Note.FilePath));
        await OnSaved.InvokeAsync();
    }

    [JSInvokable]
    public async Task<string?> SaveClipboardImageAsync()
    {
#if WINDOWS
        try
        {
            // GetContent() has STA affinity — use sync lambda (async lambda breaks clipboard access)
            Windows.ApplicationModel.DataTransfer.DataPackageView? content = null;
            await MainThread.InvokeOnMainThreadAsync(() =>
                content = Windows.ApplicationModel.DataTransfer.Clipboard.GetContent());

            if (content == null) return null;

            byte[]? pngBytes = null;

            // Try PNG format first (raw bytes, no conversion needed)
            if (content.Contains("PNG"))
            {
                try
                {
                    var obj = await content.GetDataAsync("PNG");
                    if (obj is Windows.Storage.Streams.IRandomAccessStream ras1)
                    {
                        var sz = (int)ras1.Size;
                        var buf = new byte[sz];
                        using var dr = new Windows.Storage.Streams.DataReader(ras1);
                        await dr.LoadAsync((uint)sz);
                        dr.ReadBytes(buf);
                        pngBytes = buf;
                    }
                    else if (obj is Windows.Storage.Streams.RandomAccessStreamReference ras2)
                    {
                        using var stream = await ras2.OpenReadAsync();
                        var sz = (int)stream.Size;
                        var buf = new byte[sz];
                        using var dr = new Windows.Storage.Streams.DataReader(stream);
                        await dr.LoadAsync((uint)sz);
                        dr.ReadBytes(buf);
                        pngBytes = buf;
                    }
                }
                catch { /* fall through to Bitmap */ }
            }

            // Fallback: Bitmap format → decode and re-encode as PNG
            if (pngBytes == null && content.Contains(Windows.ApplicationModel.DataTransfer.StandardDataFormats.Bitmap))
            {
                try
                {
                    var streamRef = await content.GetBitmapAsync();
                    using var ras = await streamRef.OpenReadAsync();
                    var decoder = await Windows.Graphics.Imaging.BitmapDecoder.CreateAsync(ras);
                    var softBitmap = await decoder.GetSoftwareBitmapAsync();
                    using var pngStream = new Windows.Storage.Streams.InMemoryRandomAccessStream();
                    var encoder = await Windows.Graphics.Imaging.BitmapEncoder.CreateAsync(
                        Windows.Graphics.Imaging.BitmapEncoder.PngEncoderId, pngStream);
                    encoder.SetSoftwareBitmap(softBitmap);
                    await encoder.FlushAsync();
                    var sz = (int)pngStream.Size;
                    var buf = new byte[sz];
                    using var dr = new Windows.Storage.Streams.DataReader(pngStream.GetInputStreamAt(0));
                    await dr.LoadAsync((uint)sz);
                    dr.ReadBytes(buf);
                    pngBytes = buf;
                }
                catch { /* no image on clipboard */ }
            }

            if (pngBytes == null) return null;

            var attachmentsDir = Path.Combine(VaultPath, "attachments");
            Directory.CreateDirectory(attachmentsDir);
            int n = 1;
            string filePath;
            do { filePath = Path.Combine(attachmentsDir, $"{Note.Id}-{n}.png"); n++; }
            while (File.Exists(filePath));
            await File.WriteAllBytesAsync(filePath, pngBytes);
            return $"attachments/{Path.GetFileName(filePath)}";
        }
        catch
        {
            return null;
        }
#else
        return null;
#endif
    }

    private static string RenderTitleLinks(string title) =>
        System.Text.RegularExpressions.Regex.Replace(title, @"\[\[([^\]]+)\]\]", m =>
        {
            var link = m.Groups[1].Value;
            var encoded = System.Net.WebUtility.HtmlEncode(link);
            return $"<span class=\"wiki-link\" data-wikilink=\"{encoded}\">{encoded}</span>";
        });

    private static string StripLeadingH1(string content)
    {
        if (!content.StartsWith("# ") && !content.StartsWith("#\t")) return content;
        var nl = content.IndexOf('\n');
        return nl < 0 ? string.Empty : content[(nl + 1)..].TrimStart('\r', '\n');
    }

    // Returns the number of file lines removed by StripLeadingH1 so that task-button
    // line numbers stay in sync with the actual file (H1 line + any trailing blank lines).
    private static int GetH1LineOffset(string content)
    {
        if (!content.StartsWith("# ") && !content.StartsWith("#\t")) return 0;
        var nl = content.IndexOf('\n');
        if (nl < 0) return 1;
        var afterNl = content[(nl + 1)..];
        var trimmed = afterNl.TrimStart('\r', '\n');
        var removedPrefix = afterNl[..(afterNl.Length - trimmed.Length)];
        return 1 + removedPrefix.Count(c => c == '\n');
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
        EditModeCoordinator.ExitEditMode(Note.Id);
    }
}
