@inject INavigationService NavService
@inject IJSRuntime JS
@inject EditModeCoordinatorService EditModeCoordinator
@implements IDisposable
@using WitteNog.App.Models
@using WitteNog.App.Services

<div class="tab-bar" @ref="_tabBar">
    @foreach (var tab in NavService.Tabs)
    {
        <div class="tab @(tab.Id == NavService.ActiveTab?.Id ? "active" : "")"
             data-action="activate" data-tabid="@tab.Id">
            <span>@(tab.Type == TabType.DailyPage ? "📅 " : tab.Type == TabType.TasksPage ? "☑ " : "🏷️ ")@tab.Title</span>
            @if (NavService.Tabs.Count > 1)
            {
                <button class="close-btn"
                        data-action="close" data-tabid="@tab.Id">×</button>
            }
        </div>
    }
</div>

@code {
    private ElementReference _tabBar;
    private DotNetObjectReference<TabBar>? _dotNetRef;

    protected override void OnInitialized() => NavService.TabsChanged += Refresh;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("TabDelegate.attach", _tabBar, _dotNetRef);
        }
    }

    [JSInvokable]
    public async Task HandleAction(string action, string tabId)
    {
        if (EditModeCoordinator.IsInEditMode && action is "activate" or "close" or "close-active")
        {
            await JS.InvokeVoidAsync("alert", "Sla eerst op of annuleer de bewerking voordat je van tabblad wisselt.");
            return;
        }

        if (action == "activate")
            NavService.SetActiveTab(tabId);
        else if (action == "close")
            NavService.CloseTab(tabId);
        else if (action == "close-active" && NavService.ActiveTab is { } active)
            NavService.CloseTab(active.Id);
        await InvokeAsync(StateHasChanged);
    }

    private void Refresh() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        NavService.TabsChanged -= Refresh;
        _dotNetRef?.Dispose();
    }
}
