@inject IMediator Mediator
@inject VaultWatcherService Watcher
@inject ILinkMetadataService MetadataService
@inject IVaultSettings VaultSettings
@inject IJSRuntime JS
@implements IDisposable
@using MediatR
@using WitteNog.App.Models
@using WitteNog.App.Pages
@using WitteNog.App.Services
@using WitteNog.Application.Commands
@using WitteNog.Application.Models
@using WitteNog.Application.Queries
@using WitteNog.Core.Events
@using WitteNog.Core.Interfaces
@using WitteNog.Core.Models

@if (Tab.Type == TabType.TasksPage)
{
    <TaskDashboard VaultPath="@VaultPath" />
}
else
{
<div class="virtual-canvas" @ref="_canvasEl">
    <div class="canvas-header">
        <h2>
            @(Tab.Type == TabType.DailyPage ? "📅" : "🏷️") @Tab.Query
            @if (_isArchived)
            {
                <span class="archive-badge">[Gearchiveerd]</span>
            }
        </h2>
        <div class="canvas-header-actions">
            <button class="collapse-all-btn" @onclick="ToggleCollapseAll"
                    title="@(_allCollapsed ? "Alles uitklappen" : "Alles inklappen")">
                @(_allCollapsed ? "▸▸ Uitklappen" : "▾▾ Inklappen")
            </button>
            <NewNoteButton VaultPath="@VaultPath" PageLink="@Tab.Query" OnNoteCreated="RefreshAsync" />
            <NewFlowButton VaultPath="@VaultPath" PageLink="@Tab.Query" OnFlowCreated="RefreshAsync" />
        </div>
    </div>

    @if (_error != null)
    {
        <p class="error-state">Fout: @_error</p>
    }
    else if (_blocks == null)
    {
        <p class="loading">Laden...</p>
    }
    else if (!_blocks.Any())
    {
        <p class="empty-state">Geen notities voor @Tab.Query. Maak er een aan met "+ Nieuw".</p>
    }
    else
    {
        @foreach (var block in _blocks)
        {
            @if (block.IsNote)
            {
                <div id="note-@block.Note!.Id">
                    <NoteBlock Note="@block.Note" VaultPath="@VaultPath" TabQuery="@Tab.Query" OnSaved="RefreshAsync" />
                </div>
            }
            else
            {
                <div id="flow-@SanitizeId(block.Flow!.Id)">
                    <FlowBlock Flow="@block.Flow" VaultPath="@VaultPath" OnSaved="RefreshAsync" />
                </div>
            }
        }
    }
</div>
}

@code {
    [Parameter] public string VaultPath { get; set; } = string.Empty;
    [Parameter] public TabViewModel Tab { get; set; } = null!;

    private IReadOnlyList<VaultBlock>? _blocks;
    private bool _isArchived;
    private string? _error;
    private ElementReference _canvasEl;
    private bool _allCollapsed;

    protected override async Task OnParametersSetAsync()
    {
        _isArchived = Tab.Type == TabType.TopicPage
                   && MetadataService.IsArchived(VaultPath, Tab.Query);

        MetadataService.MetadataChanged -= OnMetadataChanged;
        MetadataService.MetadataChanged += OnMetadataChanged;

        Watcher.NoteChanged -= OnExternalChange;
        Watcher.NoteChanged += OnExternalChange;
        Watcher.MetadataChanged -= OnExternalMetadataChange;
        Watcher.MetadataChanged += OnExternalMetadataChange;
        if (!string.IsNullOrEmpty(VaultPath))
            Watcher.StartWatching(VaultPath);
        await RefreshAsync();
    }

    private async Task RefreshAsync()
    {
        if (string.IsNullOrEmpty(VaultPath)) return;

        try
        {
            _error = null;

            var notesTask = Tab.Type == TabType.DailyPage
                ? Mediator.Send(new GetNotesForDateQuery(VaultPath, Tab.Query))
                : Mediator.Send(new GetNotesForTopicQuery(VaultPath, Tab.Query));
            var flowsTask = Tab.Type == TabType.DailyPage
                ? Mediator.Send(new GetFlowsForDateQuery(VaultPath, Tab.Query))
                : Mediator.Send(new GetFlowsForTopicQuery(VaultPath, Tab.Query));

            await Task.WhenAll(notesTask, flowsTask);
            var notes = notesTask.Result;
            var flows = flowsTask.Result;

            // Auto-create placeholder note for daily pages
            if (Tab.Type == TabType.DailyPage && !notes.Any(n => n.Id == Tab.Query))
            {
                await Mediator.Send(new CreateNoteCommand(VaultPath, Tab.Query, $"[[{Tab.Query}]]"));
                notes = await Mediator.Send(new GetNotesForDateQuery(VaultPath, Tab.Query));
                var template = VaultSettings.GetDailyTemplate(VaultPath);
                var initialContent = string.IsNullOrWhiteSpace(template)
                    ? $"[[{Tab.Query}]]"
                    : $"[[{Tab.Query}]]\n\n{template}";
                await Mediator.Send(new CreateNoteCommand(VaultPath, Tab.Query, initialContent));
                notes = await Mediator.Send(new GetNotesForDateQuery(VaultPath, Tab.Query));
            }

            // Definition note stays first; remaining notes + flows sorted by LastModified descending
            var defNote = notes.FirstOrDefault(n => n.Content.Trim() == $"[[{Tab.Query}]]");
            var remaining = notes
                .Where(n => n != defNote)
                .Select(VaultBlock.FromNote)
                .Concat(flows.Select(VaultBlock.FromFlow))
                .OrderByDescending(b => b.LastModified);

            _blocks = defNote is not null
                ? new[] { VaultBlock.FromNote(defNote) }.Concat(remaining).ToList()
                : remaining.ToList();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }

        _allCollapsed = false;
        await InvokeAsync(StateHasChanged);
    }

    private async Task ToggleCollapseAll()
    {
        _allCollapsed = !_allCollapsed;
        await JS.InvokeVoidAsync("HeadingCollapse.setAll", _canvasEl, _allCollapsed);
    }

    private void OnMetadataChanged()
    {
        _isArchived = Tab.Type == TabType.TopicPage
                   && MetadataService.IsArchived(VaultPath, Tab.Query);
        InvokeAsync(StateHasChanged);
    }

    private void OnExternalChange(NoteChangedEvent _) => InvokeAsync(RefreshAsync);

    private void OnExternalMetadataChange()
    {
        MetadataService.InvalidateCache(VaultPath);
        _isArchived = Tab.Type == TabType.TopicPage
                   && MetadataService.IsArchived(VaultPath, Tab.Query);
        InvokeAsync(StateHasChanged);
    }

    private static string SanitizeId(string id) =>
        System.Text.RegularExpressions.Regex.Replace(id, @"[^\w\-]", "_");

    public void Dispose()
    {
        Watcher.NoteChanged -= OnExternalChange;
        Watcher.MetadataChanged -= OnExternalMetadataChange;
        MetadataService.MetadataChanged -= OnMetadataChanged;
    }
}
