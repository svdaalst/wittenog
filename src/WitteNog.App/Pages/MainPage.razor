@page "/"
@inject INavigationService NavService
@inject VaultContextService VaultContext
@inject VaultWatcherService Watcher
@inject ILinkMetadataService MetadataService
@inject IUpdateService UpdateService
@inject IJSRuntime JS
@implements IDisposable
@using WitteNog.App.Components
@using WitteNog.App.Models
@using WitteNog.App.Pages
@using WitteNog.App.Services
@using WitteNog.Core.Interfaces
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop

@if (!VaultContext.IsConfigured)
{
    <OnboardingPage OnVaultSelected="@OnVaultSelected" />
}
else
{
    <ErrorBoundary @ref="_boundary">
        <ChildContent>
            <div class="app-shell">
                <div class="top-bar" @ref="_topBar">
                    <button class="hamburger-btn" @onclick="ToggleSidebar" title="Menu">☰</button>
                    <TabBar />
                    <button class="tasks-btn" title="Taken" @onclick="OpenTasksTab">☑</button>
                    <button class="settings-btn" title="Instellingen" data-action="settings">⚙</button>
                </div>
                <div class="content-area">
                    <div class="sidebar-overlay @(_sidebarOpen ? "visible" : "")" @onclick="CloseSidebar"></div>
                    <WikiLinkSidebar VaultPath="@VaultPath" IsOpen="@_sidebarOpen" />
                    <main class="canvas-area">
                        @if (NavService.ActiveTab is not null)
                        {
                            <VirtualCanvas VaultPath="@VaultPath" Tab="@NavService.ActiveTab" />
                        }
                    </main>
                </div>
            </div>
            <div class="fab-group">
                <button class="fab" @onclick="OpenTodayFab" title="Vandaag openen">+</button>
            </div>
        </ChildContent>
        <ErrorContent Context="ex">
            <div style="padding:20px;color:red;font-family:monospace;white-space:pre-wrap">
                <b>Fout:</b> @ex.Message
                <br/>@ex.StackTrace
            </div>
        </ErrorContent>
    </ErrorBoundary>

    <GlobalRecordingIndicator />

    @if (_showSettings)
    {
        <SettingsPage OnClose="@OnSettingsClosed" />
    }

    @if (_archiveWarning != null)
    {
        <div class="archive-guard-toast" @onclick="() => _archiveWarning = null">
            Waarschuwing: [[  @_archiveWarning]] heeft nog openstaande taken.
        </div>
    }

    @if (_updateVersion != null)
    {
        <div class="update-toast" @ref="_updateToast">
            @if (_updating)
            {
                <span>Bijwerken… @_updateProgress%</span>
            }
            else
            {
                <span>Versie @_updateVersion beschikbaar</span>
                <button data-action="apply-update">Bijwerken</button>
                <button data-action="dismiss-update">✕</button>
            }
        </div>
    }
}

@code {
    private ErrorBoundary? _boundary;
    private bool _showSettings;
    private string? _archiveWarning;
    private bool _sidebarOpen;
    private ElementReference _topBar;
    private DotNetObjectReference<MainPage>? _dotNetRef;
    private string? _updateVersion;
    private bool _updating;
    private int _updateProgress;
    private ElementReference _updateToast;
    private bool _updateToastAttached;

    private string VaultPath => VaultContext.VaultPath ?? string.Empty;

    protected override void OnInitialized()
    {
        NavService.TabsChanged += Refresh;
        VaultContext.VaultPathChanged += OnVaultPathChanged;
        MetadataService.ArchiveGuardTriggered += OnArchiveGuardTriggered;
        EnsureVaultDirectories();
        if (VaultContext.IsConfigured)
            Watcher.StartWatching(VaultPath);
        _ = CheckForUpdateAsync();
    }

    private async Task CheckForUpdateAsync()
    {
        try
        {
            var version = await UpdateService.CheckForUpdateAsync();
            if (version is not null)
            {
                _updateVersion = version;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch
        {
            // Geen netwerk of GitHub onbereikbaar — stilletjes negeren
        }
    }

    private async Task ApplyUpdate()
    {
        if (_updateVersion is null) return;
        _updating = true;
        await InvokeAsync(StateHasChanged);
        var progress = new Progress<int>(p =>
        {
            _updateProgress = p;
            InvokeAsync(StateHasChanged);
        });
        try
        {
            await UpdateService.DownloadAndApplyUpdateAsync(_updateVersion, progress);
        }
        catch
        {
            _updating = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && VaultContext.IsConfigured)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("OnboardingDelegate.attach", _topBar, _dotNetRef);
        }

        if (!_updateToastAttached && _updateVersion != null && _dotNetRef != null)
        {
            _updateToastAttached = true;
            await JS.InvokeVoidAsync("OnboardingDelegate.attach", _updateToast, _dotNetRef);
        }
    }

    [JSInvokable]
    public async Task HandleAction(string action)
    {
        if (action == "settings")
        {
            _showSettings = true;
            await InvokeAsync(StateHasChanged);
        }
        else if (action == "apply-update")
        {
            await ApplyUpdate();
        }
        else if (action == "dismiss-update")
        {
            _updateVersion = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private void OpenTasksTab() => NavService.OpenTab(TabType.TasksPage, "Taken");

    private void ToggleSidebar() => _sidebarOpen = !_sidebarOpen;
    private void CloseSidebar() => _sidebarOpen = false;
    private void OpenTodayFab() =>
        NavService.OpenTab(TabType.DailyPage, DateTimeOffset.Now.ToString("yyyy-MM-dd"));

    private void OnSettingsClosed()
    {
        _showSettings = false;
        InvokeAsync(StateHasChanged);
    }

    private void OnArchiveGuardTriggered(string link)
    {
        _archiveWarning = link;
        InvokeAsync(StateHasChanged);
    }

    private void EnsureVaultDirectories()
    {
        if (string.IsNullOrEmpty(VaultPath)) return;
        Directory.CreateDirectory(VaultPath);
        Directory.CreateDirectory(Path.Combine(VaultPath, ".metadata"));
        Directory.CreateDirectory(Path.Combine(VaultPath, "recordings"));
    }

    private void OnVaultSelected()
    {
        EnsureVaultDirectories();
        Watcher.StartWatching(VaultPath);
        InvokeAsync(StateHasChanged);
    }

    private void OnVaultPathChanged()
    {
        NavService.ClearTabs();
        EnsureVaultDirectories();
        Watcher.StartWatching(VaultPath);
        InvokeAsync(StateHasChanged);
    }

    private void Refresh()
    {
        _boundary?.Recover();
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        NavService.TabsChanged -= Refresh;
        VaultContext.VaultPathChanged -= OnVaultPathChanged;
        MetadataService.ArchiveGuardTriggered -= OnArchiveGuardTriggered;
        _dotNetRef?.Dispose();
    }
}
