@using MediatR
@using WitteNog.App.Models
@using WitteNog.App.Services
@using WitteNog.Application.Commands
@using WitteNog.Application.Queries
@using WitteNog.Core.Events
@using WitteNog.Core.Interfaces
@using WitteNog.Core.Models
@using Microsoft.JSInterop
@inject IMediator Mediator
@inject VaultContextService VaultContext
@inject VaultWatcherService Watcher
@inject INavigationService NavService
@inject IJSRuntime JS
@implements IDisposable

<div class="task-dashboard-page" @ref="_container">
    <div class="canvas-header">
        <h2>☑ Taken</h2>
        <div class="canvas-header-actions">
            <button class="collapse-all-btn" data-action="rescan" title="Bestanden opnieuw scannen">↺ Vernieuwen</button>
        </div>
    </div>

    @if (_infoMessage != null)
    {
        <div class="archive-guard-toast" style="background:#1e4620" data-action="dismiss-info">@_infoMessage</div>
    }
    @if (_errorMessage != null)
    {
        <div class="archive-guard-toast" data-action="dismiss-error">@_errorMessage</div>
    }

    @* ── Filters ──────────────────────────────────────────────────────── *@
    <div class="task-filters">
        <div class="task-filter-group">
            <label>Project:</label>
            <select @bind="_filterProject">
                <option value="">Alle projecten</option>
                @foreach (var proj in AvailableProjects)
                {
                    <option value="@proj">@proj</option>
                }
            </select>
        </div>
        <div class="task-filter-group">
            <label>Prioriteit:</label>
            <select @bind="_filterPriority">
                <option value="0">Alle prioriteiten</option>
                <option value="1">P1 - Hoog</option>
                <option value="2">P2</option>
                <option value="3">P3</option>
                <option value="4">P4</option>
                <option value="5">P5 - Laag</option>
            </select>
        </div>
    </div>

    @* ── Task table ───────────────────────────────────────────────────── *@
    @if (_tasks == null)
    {
        <p class="loading">Laden...</p>
    }
    else if (!FilteredTasks.Any())
    {
        <p class="empty-state">Geen openstaande taken gevonden.</p>
    }
    else
    {
        <table class="task-table">
            <thead>
                <tr>
                    <th></th>
                    <th>Omschrijving</th>
                    <th>Bron</th>
                    <th>Prioriteit</th>
                    <th>Deadline</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var task in FilteredTasks)
                {
                    <tr class="task-row">
                        <td>
                            <button class="complete-task-btn"
                                    title="Markeer als voltooid"
                                    data-action="complete"
                                    data-taskid="@task.Id">☐</button>
                        </td>
                        <td class="task-desc">@task.Description</td>
                        <td class="task-source">
                            <button class="source-link"
                                    data-action="open-source"
                                    data-filepath="@task.FilePath"
                                    title="Open @System.IO.Path.GetFileNameWithoutExtension(task.FilePath)">
                                @System.IO.Path.GetFileNameWithoutExtension(task.FilePath)
                            </button>
                            @if (task.ProjectLink != null)
                            {
                                <span class="wiki-chip">[[@task.ProjectLink]]</span>
                            }
                        </td>
                        <td class="task-priority @PriorityClass(task.Priority)">
                            @(task.Priority.HasValue ? $"P{task.Priority}" : "—")
                        </td>
                        <td class="task-deadline @(IsOverdue(task) ? "overdue" : "")">
                            @(task.Deadline?.ToString("yyyy-MM-dd") ?? "—")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    [Parameter] public string VaultPath { get; set; } = string.Empty;

    private IReadOnlyList<TaskItem>? _tasks;
    private string _filterProject = string.Empty;
    private int _filterPriority;
    private string? _errorMessage;
    private string? _infoMessage;
    private ElementReference _container;
    private DotNetObjectReference<TaskDashboard>? _dotNetRef;

    protected override async Task OnParametersSetAsync()
    {
        Watcher.NoteChanged -= OnExternalChange;
        Watcher.NoteChanged += OnExternalChange;
        Watcher.MetadataChanged -= OnMetadataChange;
        Watcher.MetadataChanged += OnMetadataChange;
        await RefreshAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("TaskDelegate.attach", _container, _dotNetRef);
        }
    }

    [JSInvokable]
    public async Task HandleAction(string action, string data)
    {
        if (action == "complete")
            await CompleteTaskById(data);
        else if (action == "open-source")
            await OpenSourceNote(data);
        else if (action == "rescan")
            await RescanAsync();
        else if (action == "dismiss-info")
        {
            _infoMessage = null;
            await InvokeAsync(StateHasChanged);
        }
        else if (action == "dismiss-error")
        {
            _errorMessage = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RefreshAsync(string? vaultPath = null)
    {
        vaultPath ??= VaultContext.VaultPath ?? VaultPath;
        if (string.IsNullOrEmpty(vaultPath)) return;
        _tasks = await Mediator.Send(new GetAllTasksQuery(vaultPath));
        await InvokeAsync(StateHasChanged);
    }

    private async Task RescanAsync()
    {
        _tasks = null;
        await InvokeAsync(StateHasChanged);
        Watcher.TriggerManualRefresh();
        await RefreshAsync();
    }

    private IEnumerable<TaskItem> FilteredTasks
    {
        get
        {
            if (_tasks == null) return [];
            var result = _tasks.AsEnumerable();
            if (!string.IsNullOrEmpty(_filterProject))
                result = result.Where(t =>
                    string.Equals(t.ProjectLink, _filterProject, StringComparison.OrdinalIgnoreCase));
            if (_filterPriority > 0)
                result = result.Where(t => t.Priority == _filterPriority);
            return result;
        }
    }

    private IEnumerable<string> AvailableProjects =>
        _tasks == null
            ? []
            : _tasks
                .Where(t => t.ProjectLink != null)
                .Select(t => t.ProjectLink!)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(p => p);

    private async Task OpenSourceNote(string filePath)
    {
        if (string.IsNullOrEmpty(filePath)) return;
        var slug = System.IO.Path.GetFileNameWithoutExtension(filePath);
        var type = System.Text.RegularExpressions.Regex.IsMatch(slug, @"^\d{4}-\d{2}-\d{2}$")
            ? TabType.DailyPage : TabType.TopicPage;
        NavService.OpenTab(type, slug);
        await JS.InvokeVoidAsync("scrollToNote", slug);
    }

    private async Task CompleteTaskById(string taskId)
    {
        var vaultPath = VaultContext.VaultPath ?? VaultPath;
        if (string.IsNullOrEmpty(vaultPath))
        {
            _errorMessage = "Kluis is niet geconfigureerd. Herstart de app en probeer het opnieuw.";
            await InvokeAsync(StateHasChanged);
            return;
        }
        _errorMessage = null;
        _infoMessage = null;
        var taskDesc = _tasks?.FirstOrDefault(t => t.Id == taskId)?.Description ?? taskId;
        try
        {
            await Mediator.Send(new CompleteTaskCommand(vaultPath, taskId));
        }
        catch (Exception ex)
        {
            _errorMessage = $"Taak kon niet worden voltooid: {ex.Message}";
            await InvokeAsync(StateHasChanged);
            return;
        }
        _infoMessage = $"✓ Afgevinkt: {taskDesc}";
        await RefreshAsync(vaultPath);
    }

    private static string PriorityClass(int? priority) => priority switch
    {
        1 => "priority-high",
        2 => "priority-medium-high",
        3 => "priority-medium",
        4 => "priority-medium-low",
        5 => "priority-low",
        _ => string.Empty
    };

    private static bool IsOverdue(TaskItem task) =>
        task.Deadline.HasValue && task.Deadline.Value < DateOnly.FromDateTime(DateTime.Today);

    private void OnExternalChange(NoteChangedEvent _) => InvokeAsync(() => RefreshAsync());
    private void OnMetadataChange() => InvokeAsync(() => RefreshAsync());

    public void Dispose()
    {
        Watcher.NoteChanged -= OnExternalChange;
        Watcher.MetadataChanged -= OnMetadataChange;
        _dotNetRef?.Dispose();
    }
}
