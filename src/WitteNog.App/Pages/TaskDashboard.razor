@using MediatR
@using WitteNog.App.Components
@using WitteNog.App.Models
@using WitteNog.App.Services
@using WitteNog.Application.Queries
@using WitteNog.Core.Events
@using WitteNog.Core.Interfaces
@using WitteNog.Core.Models
@using Microsoft.JSInterop
@inject IMediator Mediator
@inject VaultContextService VaultContext
@inject VaultWatcherService Watcher
@inject IJSRuntime JS
@implements IDisposable

<div class="task-dashboard-page" @ref="_container">
    <div class="canvas-header">
        <h2>☑ Taken</h2>
        <div class="canvas-header-actions">
            <button class="collapse-all-btn" data-action="rescan" title="Bestanden opnieuw scannen">↺ Vernieuwen</button>
            <button class="task-help-btn" data-action="show-help" title="Uitleg taakinvoer">?</button>
        </div>
    </div>

    @if (_showHelp)
    {
        <div class="task-help-overlay" data-action="dismiss-help">
            <div class="task-help-modal" data-action="noop">
                <button class="task-help-close" data-action="dismiss-help">✕</button>
                <h3>Taken aanmaken in markdown</h3>
                <p class="task-help-intro">Voeg een taak toe aan een willekeurig markdown-bestand met de volgende syntax:</p>

                <div class="task-help-section">
                    <div class="task-help-label">Basisregel</div>
                    <code>- [ ] Beschrijving van de taak</code>
                </div>

                <div class="task-help-section">
                    <div class="task-help-label">Prioriteit instellen <span class="task-help-hint">(!P1 t/m !P5 — P1 is hoogst)</span></div>
                    <code>- [ ] Urgente taak !P1</code>
                    <code>- [ ] Normale taak !P3</code>
                </div>

                <div class="task-help-section">
                    <div class="task-help-label">Deadline instellen <span class="task-help-hint">(@@JJJJ-MM-DD)</span></div>
                    <code>- [ ] Taak inleveren @@2026-04-15</code>
                </div>

                <div class="task-help-section">
                    <div class="task-help-label">Project koppelen <span class="task-help-hint">([[WikiLink]])</span></div>
                    <code>- [ ] [[MijnProject]] Taak omschrijving</code>
                </div>

                <div class="task-help-section">
                    <div class="task-help-label">Combinatie</div>
                    <code>- [ ] [[Project]] Taak @@2026-04-20 !P2</code>
                </div>
            </div>
        </div>
    }

    @if (_infoMessage != null)
    {
        <div class="archive-guard-toast" style="background:#1e4620" data-action="dismiss-info">@_infoMessage</div>
    }
    @if (_errorMessage != null)
    {
        <div class="archive-guard-toast" data-action="dismiss-error">@_errorMessage</div>
    }

    <div class="task-filters">
        <div class="task-filter-group">
            <label>Project:</label>
            <select @bind="_filterProject">
                <option value="">Alle projecten</option>
                @foreach (var proj in AvailableProjects)
                {
                    <option value="@proj">@proj</option>
                }
            </select>
        </div>
        <div class="task-filter-group">
            <label>Prioriteit:</label>
            <select @bind="_filterPriority">
                <option value="0">Alle prioriteiten</option>
                <option value="1">P1 - Hoog</option>
                <option value="2">P2</option>
                <option value="3">P3</option>
                <option value="4">P4</option>
                <option value="5">P5 - Laag</option>
            </select>
        </div>
    </div>

    @{
        var visibleTasks = _tasks == null ? null : FilteredTasks.ToList();
    }

    @if (visibleTasks == null)
    {
        <p class="loading">Laden...</p>
    }
    else if (visibleTasks.Count == 0)
    {
        <p class="empty-state">Geen openstaande taken gevonden.</p>
    }
    else
    {
        <TaskTable Tasks="@visibleTasks"
                   VaultPath="@(VaultContext.VaultPath ?? VaultPath)"
                   OnCompleted="OnTaskCompleted"
                   OnError="OnTaskError" />
    }
</div>

@code {
    [Parameter] public string VaultPath { get; set; } = string.Empty;

    private IReadOnlyList<TaskItem>? _tasks;
    private string _filterProject = string.Empty;
    private int _filterPriority;
    private string? _errorMessage;
    private string? _infoMessage;
    private bool _showHelp;
    private ElementReference _container;
    private DotNetObjectReference<TaskDashboard>? _dotNetRef;

    protected override async Task OnParametersSetAsync()
    {
        Watcher.NoteChanged -= OnExternalChange;
        Watcher.NoteChanged += OnExternalChange;
        Watcher.MetadataChanged -= OnMetadataChange;
        Watcher.MetadataChanged += OnMetadataChange;
        await RefreshAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("TaskDelegate.attach", _container, _dotNetRef);
        }
    }

    [JSInvokable]
    public async Task HandleAction(string action, string data)
    {
        if (action == "rescan")
            await RescanAsync();
        else if (action == "dismiss-info")
        {
            _infoMessage = null;
            await InvokeAsync(StateHasChanged);
        }
        else if (action == "dismiss-error")
        {
            _errorMessage = null;
            await InvokeAsync(StateHasChanged);
        }
        else if (action == "show-help")
        {
            _showHelp = true;
            await InvokeAsync(StateHasChanged);
        }
        else if (action == "dismiss-help")
        {
            _showHelp = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnTaskCompleted(string description)
    {
        _infoMessage = $"✓ Afgevinkt: {description}";
        await RefreshAsync();
    }

    private async Task OnTaskError(string message)
    {
        _errorMessage = message;
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshAsync(string? vaultPath = null)
    {
        vaultPath ??= VaultContext.VaultPath ?? VaultPath;
        if (string.IsNullOrEmpty(vaultPath)) return;
        _tasks = await Mediator.Send(new GetAllTasksQuery(vaultPath));
        await InvokeAsync(StateHasChanged);
    }

    private async Task RescanAsync()
    {
        _tasks = null;
        await InvokeAsync(StateHasChanged);
        Watcher.TriggerManualRefresh();
        await RefreshAsync();
    }

    private IEnumerable<TaskItem> FilteredTasks
    {
        get
        {
            if (_tasks == null) return [];
            var result = _tasks.AsEnumerable();
            if (!string.IsNullOrEmpty(_filterProject))
                result = result.Where(t =>
                    string.Equals(t.ProjectLink, _filterProject, StringComparison.OrdinalIgnoreCase));
            if (_filterPriority > 0)
                result = result.Where(t => t.Priority == _filterPriority);
            return result;
        }
    }

    private IEnumerable<string> AvailableProjects =>
        _tasks == null
            ? []
            : _tasks
                .Where(t => t.ProjectLink != null)
                .Select(t => t.ProjectLink!)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .OrderBy(p => p);

    private void OnExternalChange(NoteChangedEvent _) => InvokeAsync(() => RefreshAsync());
    private void OnMetadataChange() => InvokeAsync(() => RefreshAsync());

    public void Dispose()
    {
        Watcher.NoteChanged -= OnExternalChange;
        Watcher.MetadataChanged -= OnMetadataChange;
        _dotNetRef?.Dispose();
    }
}
